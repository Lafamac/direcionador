<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_9"
    tools:context=".Centralizador.CentralizadorRelatorio">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/centRel_voltar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:elevation="0dp"
        android:src="@drawable/seta_voltar_preta"
        app:backgroundTint="@color/ap_transparent"
        app:borderWidth="0dp"
        app:elevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:maxImageSize="36dp"
        app:pressedTranslationZ="0dp"
        app:rippleColor="@color/ap_transparent" />

    <TextView
        style="@style/textoBoldBlack"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="26dp"
        android:text="@string/centRelatorioTitulo"
        android:gravity="center_vertical"
        android:autoSizeTextType="uniform"
        android:autoSizeMaxTextSize="22sp"
        app:layout_constraintBottom_toTopOf="@+id/centRel_guide1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/centRel_voltar" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centRel_guide1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.15" />

    <androidx.constraintlayout.widget.ConstraintLayout
        style="@style/CamposDeTexto"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        app:layout_constraintBottom_toTopOf="@+id/centRel_guide2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/centRel_guide1" >

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/centRel_guide3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.12" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/centRel_guide4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.88" />

        <LinearLayout
            android:background="@drawable/fundo_branco_borda"
            android:id="@+id/centRel_datas"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="10dp"
            app:layout_constraintHeight_percent="0.1"
            app:layout_constraintEnd_toStartOf="@+id/centRel_guide4"
            app:layout_constraintStart_toStartOf="@+id/centRel_guide3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/centRel_layout1">

            <com.skydoves.powerspinner.PowerSpinnerView
                android:id="@+id/centRel_spinnerDatas"
                style="@style/PowerSpinnerStyle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:hint="@string/selecionarOpcao"
                android:gravity="center"
                app:spinner_arrow_show="false"
                app:spinner_divider_color="@color/black"
                app:spinner_divider_show="false"
                app:spinner_divider_size="0.4dp"
                app:spinner_item_height="30dp"
                app:spinner_popup_background="@drawable/fundo_branco"
                app:spinner_popup_elevation="15dp"
                app:spinner_popup_max_height="350dp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/centRel_desE"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:src="@drawable/setarel"
            android:rotation="180"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toTopOf="@id/centRel_linha1"
            app:layout_constraintStart_toStartOf="@+id/centRel_guide3"
            app:layout_constraintTop_toBottomOf="@id/centRel_datas"
            app:layout_constraintEnd_toStartOf="@id/centRel_layout1"/>

        <LinearLayout
            android:id="@+id/centRel_layout1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@+id/centRel_linha1"
            app:layout_constraintEnd_toStartOf="@+id/centRel_guide4"
            app:layout_constraintStart_toEndOf="@+id/centRel_desE"
            app:layout_constraintTop_toBottomOf="@id/centRel_datas">

            <TextView
                style="@style/textoBoldBlack"
                android:id="@+id/centRel_porcentagemE"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="2"
                android:gravity="center"
                android:maxLines="1"
                android:text="Desalinhamento - Esquerda: "
                android:autoSizeTextType="uniform"
                android:autoSizeMaxTextSize="20sp"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/centRel_linha1"
            android:layout_width="0dp"
            android:layout_height="10dp"
            android:src="@drawable/linha_cinza_claro"
            app:layout_constraintEnd_toStartOf="@+id/centRel_guide4"
            app:layout_constraintStart_toStartOf="@+id/centRel_guide3"
            app:layout_constraintTop_toBottomOf="@+id/centRel_desE"
            app:layout_constraintBottom_toTopOf="@id/centRel_cent"/>

        <ImageView
            android:id="@+id/centRel_cent"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:scaleType="fitCenter"
            android:src="@drawable/setarel3"
            android:rotation="-90"
            app:layout_constraintBottom_toTopOf="@id/centRel_linha2"
            app:layout_constraintEnd_toStartOf="@id/centRel_layout2"
            app:layout_constraintStart_toStartOf="@+id/centRel_guide3"
            app:layout_constraintTop_toBottomOf="@+id/centRel_linha1" />

        <LinearLayout
            android:id="@+id/centRel_layout2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@+id/centRel_linha2"
            app:layout_constraintEnd_toStartOf="@+id/centRel_guide4"
            app:layout_constraintStart_toEndOf="@+id/centRel_cent"
            app:layout_constraintTop_toBottomOf="@id/centRel_linha1">

            <TextView
                android:id="@+id/centRel_porcentagemC"
                style="@style/textoBoldBlack"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="2"
                android:autoSizeMaxTextSize="20sp"
                android:autoSizeTextType="uniform"
                android:gravity="center"
                android:maxLines="1"
                android:text="Centralizamento: " />

        </LinearLayout>

        <ImageView
            android:id="@+id/centRel_linha2"
            android:layout_width="0dp"
            android:layout_height="10dp"
            android:src="@drawable/linha_cinza_claro"
            app:layout_constraintEnd_toStartOf="@+id/centRel_guide4"
            app:layout_constraintStart_toStartOf="@+id/centRel_guide3"
            app:layout_constraintTop_toBottomOf="@+id/centRel_cent"
            app:layout_constraintBottom_toTopOf="@id/centRel_desD"/>

        <ImageView
            android:id="@+id/centRel_desD"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:scaleType="fitCenter"
            android:src="@drawable/setarel2"
            android:rotation="180"
            app:layout_constraintBottom_toTopOf="@id/centRel_linha3"
            app:layout_constraintEnd_toStartOf="@id/centRel_layout3"
            app:layout_constraintStart_toStartOf="@+id/centRel_guide3"
            app:layout_constraintTop_toBottomOf="@+id/centRel_linha2" />

        <LinearLayout
            android:id="@+id/centRel_layout3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@+id/centRel_linha3"
            app:layout_constraintEnd_toStartOf="@+id/centRel_guide4"
            app:layout_constraintStart_toEndOf="@+id/centRel_desD"
            app:layout_constraintTop_toBottomOf="@id/centRel_linha2">

            <TextView
                android:id="@+id/centRel_porcentagemD"
                style="@style/textoBoldBlack"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="2"
                android:autoSizeMaxTextSize="20sp"
                android:autoSizeTextType="uniform"
                android:gravity="center"
                android:maxLines="1"
                android:text="Desalinhamento - Direita: " />
        </LinearLayout>

        <ImageView
            android:id="@+id/centRel_linha3"
            android:layout_width="0dp"
            android:layout_height="10dp"
            android:src="@drawable/linha_cinza_claro"
            app:layout_constraintEnd_toStartOf="@+id/centRel_guide4"
            app:layout_constraintStart_toStartOf="@+id/centRel_guide3"
            app:layout_constraintTop_toBottomOf="@+id/centRel_desD"
            app:layout_constraintBottom_toBottomOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centRel_guide2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.9" />

    <Button
        android:id="@+id/centRel_finalizar"
        style="@style/botaoPreto"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:autoSizeMaxTextSize="18sp"
        android:autoSizeTextType="uniform"
        android:text="@string/botaoFinalizar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/centRel_guide2" />

</androidx.constraintlayout.widget.ConstraintLayout>