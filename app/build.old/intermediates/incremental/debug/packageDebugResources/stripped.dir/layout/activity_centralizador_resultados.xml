<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <!-- Lado Esquerdo com novos componentes (ImageView e LinearLayout com TextViews) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- ImageView na parte esquerda -->

        <!-- LinearLayout com TextViews -->
        <LinearLayout

            android:layout_width="624dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <LinearLayout

                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginLeft="46dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/resulSist_voltar"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:background="@drawable/custom_fundo"
                    android:elevation="10dp"
                    android:scaleType="centerInside"
                    app:layout_constraintBottom_toTopOf="@+id/guide14"
                    app:layout_constraintEnd_toStartOf="@+id/guide_Cent4"
                    app:layout_constraintHorizontal_bias="0.058"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.057"
                    app:srcCompat="@drawable/__removebg_preview_removebg_preview" />
            </LinearLayout>
            <LinearLayout

                android:layout_width="624dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/resul_imagem"
                    android:layout_width="279dp"
                    android:layout_height="258dp"
                    android:layout_margin="30dp"

                    app:srcCompat="@drawable/imagem_padrao" />


            </LinearLayout>

        </LinearLayout>


        <TextView

            android:id="@+id/nomeOp_resul"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="Nome"
            android:textSize="45sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/numOp_resul"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Operador 1"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#D6D4D6"
            android:text="Dias Trabalhados: "
            android:textColor="#000000"
            android:textSize="35sp" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B5B5B5"
            android:text="Horas Trabalhadas: "
            android:textColor="#000000"
            android:textSize="35sp" />

        <Button
            android:id="@+id/gerEd_editarImagem"
            style="@style/textoBotoes"
            android:layout_width="337dp"
            android:layout_height="51dp"
            android:layout_marginVertical="30dp"
            android:autoSizeMaxTextSize="18sp"
            android:autoSizeTextType="uniform"
            android:text="@string/botaoMaisResultados"
            app:backgroundTint="@null"
            app:layout_constraintBottom_toTopOf="@+id/gerEd_layout1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/gerEd_imagemGleba"
            app:layout_constraintWidth_percent="0.5" />

    </LinearLayout>

    <!-- Lado Direito com gráfico (6 barras verticais com porcentagens) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_horizontal">

        <!-- Barra 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="4dp"
            android:rotationX="180">
            <ImageView
                android:id="@+id/barra1"
                android:layout_width="80dp"
                android:layout_height="100dp"
                android:background="@color/red" />
            <TextView
                android:id="@+id/percentage1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="14sp"
                android:rotationX="-180"/>
        </LinearLayout>

        <!-- Barra 2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="4dp"
            android:rotationX="180">
            <ImageView
                android:id="@+id/barra2"
                android:layout_width="80dp"
                android:layout_height="200dp"
                android:background="@color/yellow" />
            <TextView
                android:id="@+id/percentage2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="14sp"
                android:rotationX="-180"/>
        </LinearLayout>

        <!-- Barra 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="4dp"
            android:rotationX="-180">
            <ImageView
                android:id="@+id/barra3"
                android:layout_width="80dp"
                android:layout_height="150dp"
                android:background="@color/dark_green" />
            <TextView
                android:id="@+id/percentage3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="14sp"
                android:rotationX="-180"/>
        </LinearLayout>

        <!-- Barra 4 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="4dp"
            android:rotationX="180">
            <ImageView
                android:id="@+id/barra4"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:background="@color/bright_green" />
            <TextView
                android:id="@+id/percentage4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="14sp"
                android:rotationX="-180"/>
        </LinearLayout>

        <!-- Barra 5 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="4dp"
            android:rotationX="180">

            <ImageView
                android:id="@+id/barra5"
                android:layout_width="80dp"
                android:layout_height="500dp"
                android:background="@color/dark_green" />
            <TextView
                android:id="@+id/percentage5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="14sp"
                android:rotationX="-180" />
        </LinearLayout>

        <!-- Barra 6 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="4dp"
            android:rotationX="180">
            <ImageView
                android:id="@+id/barra6"
                android:layout_width="80dp"
                android:layout_height="350dp"
                android:background="@color/yellow"
                android:rotationX="0" />
            <TextView
                android:id="@+id/percentage6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5%"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="4dp"
            android:rotationX="180">
            <ImageView
                android:id="@+id/barra7"
                android:layout_width="80dp"
                android:layout_height="100dp"
                android:background="@color/red" />
            <TextView
                android:id="@+id/percentage7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="14sp"
                android:rotationX="-180"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
