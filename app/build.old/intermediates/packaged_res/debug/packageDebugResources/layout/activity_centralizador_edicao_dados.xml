<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_9"
    tools:context=".Centralizador.CentralizadorEdicaoDados">

    <TextView
        style="@style/textoBoldBlack"
        android:id="@+id/gerEd_titulo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="25dp"
        android:autoSizeMaxTextSize="25sp"
        android:autoSizeTextType="uniform"
        android:gravity="center"
        android:text="@string/gerEditarTitulo"
        app:layout_constraintBottom_toTopOf="@+id/gerEd_guide1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gerEd_guide1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.12" />

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/gerEd_imagemGleba"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/imagem_padrao"
        android:scaleType="centerCrop"
        app:layout_constraintHeight_percent="0.25"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/gerEd_editarImagem"
        app:layout_constraintTop_toBottomOf="@id/gerEd_guide1" />

    <Button
        android:id="@+id/gerEd_editarImagem"
        app:backgroundTint="@null"
        style="@style/textoBotoes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintWidth_percent="0.5"
        android:autoSizeMaxTextSize="18sp"
        android:autoSizeTextType="uniform"
        android:text="@string/botaoAlterarImagem"
        app:layout_constraintBottom_toTopOf="@+id/gerEd_layout1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gerEd_imagemGleba" />

    <androidx.constraintlayout.widget.ConstraintLayout
        style="@style/FundoSobreImagem2"
        android:id="@+id/gerEd_layout1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.5">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gerEd_guide2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.06" />

        <TextView
            style="@style/textoBoldBlack"
            android:id="@+id/gerEd_local"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintHeight_percent="0.07"
            android:text="@string/gerLocal"
            android:autoSizeTextType="uniform"
            app:layout_constraintTop_toBottomOf="@id/gerEd_guide2"
            app:layout_constraintBottom_toTopOf="@id/gerEdit_campo1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/gerEdit_campo1"
            style="@style/CamposDeTexto"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="20dp"
            android:hint="@string/digiteAqui"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gerEd_local" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gerEd_guide3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.8" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gerEd_guide4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.35" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gerEd_guide5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.65" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/gerEd_cancela"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="20dp"
            android:src="@drawable/excluir"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/gerEd_guide4"
            app:layout_constraintHeight_percent="0.12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/gerEd_guide3" />

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/gerEd_confirma"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginEnd="20dp"
            android:src="@drawable/confirmar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.12"
            app:layout_constraintStart_toStartOf="@+id/gerEd_guide5"
            app:layout_constraintTop_toBottomOf="@+id/gerEd_guide3" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/gerEd_fab"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:elevation="0dp"
        android:src="@drawable/_52901_rotate_rotation_icon"
        app:backgroundTint="@color/transparente"
        app:borderWidth="0dp"
        app:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/gerEd_imagemGleba"
        app:layout_constraintEnd_toEndOf="@+id/gerEd_imagemGleba"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@+id/gerEd_imagemGleba"
        app:layout_constraintTop_toTopOf="@+id/gerEd_imagemGleba"
        app:layout_constraintVertical_bias="0.0"
        app:maxImageSize="24dp"
        app:pressedTranslationZ="0dp"
        app:fabCustomSize="46dp"
        app:rippleColor="@color/transparente" />

</androidx.constraintlayout.widget.ConstraintLayout>