<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_9"
    tools:context=".Centralizador.CentralizadorSistema2">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_Cent1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.78" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/botoes_centralizador_sistema"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guide_Cent1">

        <Button
            android:id="@+id/centSist_start"
            style="@style/textoBotoes"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="@string/botaoIniciar"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/centSist_grafico"
            app:layout_constraintHeight_percent="0.55"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.3" />


        <Button
            android:id="@+id/centSist_grafico"
            style="@style/textoBotoes"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="@string/dados"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/centSist_start"
            app:layout_constraintHeight_percent="0.55"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.3" />

        <Button
            android:id="@+id/centSist_stop"
            style="@style/textoBotoes"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="@string/botaoPausar"
            android:textSize="20sp"
            app:layout_constraintWidth_percent="0.4"
            app:layout_constraintHeight_percent="0.55"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="gone" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_Cent30H"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.31" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5346" />

    <ImageView
        android:id="@+id/centSist_setaDireita2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerInside"
        android:src="@drawable/vm"
        app:layout_constraintBottom_toTopOf="@+id/guide_Cent30H"
        app:layout_constraintEnd_toStartOf="@+id/guideline11"
        app:layout_constraintStart_toStartOf="@+id/centSist_guide13"
        app:layout_constraintTop_toTopOf="@+id/guide14" />

    <ImageView
        android:id="@+id/centSist_setaEsquerda2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:rotation="180"
        android:scaleType="centerInside"
        android:src="@drawable/am"
        app:layout_constraintBottom_toTopOf="@+id/guide_Cent30H"
        app:layout_constraintEnd_toStartOf="@+id/centSist_guide11"
        app:layout_constraintStart_toStartOf="@+id/guideline10"
        app:layout_constraintTop_toTopOf="@+id/guide14" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.14" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.4654" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/LinearLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/fundo_transparente_borda"
        android:elevation="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/guide_Cent1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.35"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guide_Cent30H"
        app:layout_constraintWidth_percent="0.9">

        <ImageView
            android:id="@+id/centSist_ledsP"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/fundo_transparente"
            android:scaleType="fitXY"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/c1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/descricao_sens"
        style="@style/textoTitulo"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.3"
        android:layout_height="wrap_content"
        android:elevation="10dp"
        android:text="@string/defaultMsgNotImplemented"
        app:layout_constraintBottom_toTopOf="@+id/guide_Cent30H"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:visibility="gone"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/centSist_media"
        style="@style/CamposDeTexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="@string/media"
        app:layout_constraintBottom_toTopOf="@+id/guide14"
        app:layout_constraintEnd_toStartOf="@+id/centSist_moda"
        app:layout_constraintStart_toStartOf="@+id/guide_Cent4"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/centSist_moda"
        style="@style/CamposDeTexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="@string/moda"
        app:layout_constraintBottom_toTopOf="@+id/guide14"
        app:layout_constraintEnd_toStartOf="@+id/centSist_movel"
        app:layout_constraintStart_toEndOf="@+id/centSist_media"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/centSist_movel"
        style="@style/CamposDeTexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="@string/modaMovel"
        app:layout_constraintBottom_toTopOf="@+id/guide14"
        app:layout_constraintEnd_toStartOf="@+id/guide_Cent5"
        app:layout_constraintStart_toEndOf="@+id/centSist_moda"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.494" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_Cent4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.12" />

    <ImageButton
        android:id="@+id/centSist_voltar"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:background="@drawable/custom_fundo"
        android:elevation="10dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toTopOf="@+id/guide14"
        app:layout_constraintEnd_toStartOf="@+id/guide_Cent4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/__removebg_preview_removebg_preview" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_Cent5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.75" />

    <Button
        android:id="@+id/centSist_marcarPe"
        style="@style/textoBotoes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:text="@string/marcarPe"
        app:layout_constraintBottom_toTopOf="@+id/guide14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guide_Cent5"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centSist_guide11"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.95" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centSist_guide13"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.05" />

</androidx.constraintlayout.widget.ConstraintLayout>