<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="PowerSpinnerStyle" parent="TextAppearance.AppCompat" tools:override="true" >
        <item name="android:background">@drawable/fundo_branco</item>
        <item name="android:scrollbarAlwaysDrawVerticalTrack">true</item>
        <item name="android:scrollbars">vertical</item>
        <item name="android:fadeScrollbars">false</item>
        <item name="android:scrollbarThumbVertical">@drawable/powerspinner_scrollbar</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="CamposDeTexto" parent="TextAppearance.AppCompat" >
        <item name="android:elevation"> 10dp </item>
        <item name="android:background"> @drawable/fundo_branco </item>
    </style>

    <style name="FundoSobreImagem" parent="TextAppearance.AppCompat" >
        <item name="elevation">10dp</item>
        <item name="android:background"> @drawable/fundo_branco_corner_top</item>
        <item name="android:backgroundTint">@color/color_10</item>
    </style>

    <style name="FundoSobreImagem2" parent="TextAppearance.AppCompat">
        <item name="elevation">10dp</item>
        <item name="android:background"> @drawable/fundo_branco_corner_top</item>
    </style>

    <style name="imagemArredondada" parent="TextAppearance.AppCompat">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="textoBotoes" parent="TextAppearance.AppCompat">
        <item name="android:textColor"> #FFFFFF </item>
        <item name="android:textAllCaps"> false </item>
        <item name="android:background">@drawable/custom_button</item>
        <item name="android:textStyle"> bold </item>
    </style>

    <style name="botoesBrancos" parent="TextAppearance.AppCompat">
        <item name="android:textColor"> #000000 </item>
        <item name="android:textAllCaps"> false </item>
        <item name="android:background">@drawable/custom_fundo_branco</item>
        <item name="android:textStyle"> normal </item>
    </style>

    <style name="botaoTransparente" parent="TextAppearance.AppCompat" >
        <item name="android:textColor"> #FFFFFF </item>
        <item name="android:textAllCaps"> false </item>
        <item name="android:background">@drawable/fundo_transparente_borda</item>
        <item name="android:textStyle"> normal </item>
    </style>

    <style name="botaoPreto" parent="TextAppearance.AppCompat" >
        <item name="android:textColor"> #FFFFFF </item>
        <item name="android:textAllCaps"> false </item>
        <item name="android:background">@drawable/custom_fundo_preto</item>
        <item name="android:textStyle"> bold </item>
    </style>

    <style name="textoTitulo" parent="TextAppearance.AppCompat">
        <item name="android:textAlignment"> center </item>
        <item name="android:textColor"> #000000 </item>
        <item name="android:background"> @drawable/fundo_branco </item>
        <item name="android:textStyle"> bold </item>
    </style>

    <style name="TituloBrancoSemFundo" parent="TextAppearance.AppCompat" >
        <item name="android:textAlignment"> center </item>
        <item name="android:textColor"> #FFFFFF </item>
        <item name="android:background"> #00FFFFFF </item>
        <item name="android:textStyle"> bold </item>
    </style>

    <style name="textoBoldBlack" parent="TextAppearance.AppCompat" >
        <item name="android:textColor"> #000000 </item>
        <item name="android:textStyle"> bold </item>
    </style>

    <style name="textoBrancoBold" parent="TextAppearance.AppCompat" >
        <item name="android:textStyle"> bold </item>
        <item name="android:textColor"> #FFFFFF </item>
    </style>

    <style name="textoBold" parent="TextAppearance.AppCompat" >
        <item name="android:textStyle"> bold </item>
        <item name="android:textColor"> #706F6D </item>
    </style>

    <style name="textoNormalBlack" parent="TextAppearance.AppCompat" >
        <item name="android:textColor"> #000000 </item>
    </style>

    <style name="textoNormal" parent="TextAppearance.AppCompat" >
        <item name="android:textColor"> #706F6D </item>
    </style>

    <style name="textoOpaco" parent="TextAppearance.AppCompat" >
        <item name="android:textColor">#BABABA</item>
    </style>

    <style name="textoBoldRed" parent="TextAppearance.AppCompat" >
        <item name="android:textStyle"> bold </item>
        <item name="android:textColor"> @color/vermelho_erro </item>
    </style>

    <style name="textoBoldVerde" parent="TextAppearance.AppCompat" >
        <item name="android:textStyle"> bold </item>
        <item name="android:textColor"> @color/verde_botoes</item>
    </style>

</resources>