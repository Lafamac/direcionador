<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/coffee_bg"
    tools:context=".Centralizador.CentralizadorPrincipal">

    <Button
        android:id="@+id/centPrin_continuar"
        style="@style/botoesBrancos"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="15dp"
        android:autoSizeMaxTextSize="20sp"
        android:autoSizeMinTextSize="14sp"
        android:autoSizeStepGranularity="1sp"
        android:autoSizeTextType="uniform"
        android:text="@string/centUtilizarSist"
        app:layout_constraintBottom_toTopOf="@+id/centPrin_admin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/centPrin_explicacao"
        app:layout_constraintVertical_bias="0.931"
        app:layout_constraintWidth_percent="0.95" />

    <Button
        android:id="@+id/centPrin_admin"
        style="@style/botoesBrancos"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="15dp"
        android:autoSizeMaxTextSize="20sp"
        android:autoSizeMinTextSize="14sp"
        android:autoSizeStepGranularity="1sp"
        android:autoSizeTextType="uniform"
        android:text="@string/centAdminMode"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/centPrin_guide4"
        app:layout_constraintVertical_bias="0.841"
        app:layout_constraintWidth_percent="0.95" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centPrin_guide2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.25" />

    <TextView
        android:id="@+id/centPrin_explicacao"
        style="@style/TituloBrancoSemFundo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="55dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:autoSizeMaxTextSize="30sp"
        android:autoSizeMinTextSize="14sp"
        android:autoSizeStepGranularity="1sp"
        android:autoSizeTextType="uniform"
        android:gravity="center"
        android:text="@string/centPrinTexto"
        app:layout_constraintBottom_toTopOf="@+id/centPrin_guide4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/centPrin_guide2"
        app:layout_constraintWidth_percent="0.9" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centPrin_guide4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.6" />

</androidx.constraintlayout.widget.ConstraintLayout>
