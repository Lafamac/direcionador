<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/fundo2"
    tools:context=".Centralizador.CentralizadorCadastro">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout7"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/guide_gerCad1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.88">

        <TextView
            android:id="@+id/txt_gerCad1"
            style="@style/textoBrancoBold"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:autoSizeMaxTextSize="26sp"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:gravity="center"
            android:visibility="visible"
            android:text="@string/gerCadastroGlebas"
            app:layout_constraintBottom_toTopOf="@id/campoBuscaGer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.35"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txt_operador"
            style="@style/textoBrancoBold"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:autoSizeMaxTextSize="26sp"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:gravity="center"
            android:visibility="gone"
            android:text="@string/Operadores"
            app:layout_constraintBottom_toTopOf="@id/campoBuscaGer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.35"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <SearchView
            android:id="@+id/campoBuscaGer"
            style="@style/CamposDeTexto"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:iconifiedByDefault="false"
            android:queryHint="@string/gerHintPesquisaGlebas"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_gerCad1"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_gerCad1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.25" />

    <androidx.constraintlayout.widget.ConstraintLayout
        style="@style/FundoSobreImagem"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guide_gerCad1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listaOperadores"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toTopOf="@+id/admin_options_layout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.95">

        </androidx.recyclerview.widget.RecyclerView>

        <TextView
            android:id="@+id/gerCad_txt"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="60dp"
            android:autoSizeMaxTextSize="22sp"
            android:autoSizeTextType="uniform"
            android:gravity="center"
            android:text="@string/gerTextoNenhumaGleba"
            app:layout_constraintBottom_toTopOf="@id/admin_options_layout"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/admin_options_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="1.0">

            <Button
                android:id="@+id/btn_configuracoes"
                style="@style/textoBotoes"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="Ajustes"
                android:textSize="18sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_relatorios"
                style="@style/textoBotoes"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="Relatórios"
                android:textSize="18sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/cadastrarOperador"
                style="@style/textoBotoes"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="Novo Operador"
                android:textSize="18sp"
                app:backgroundTint="@null" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/gerCad_fab"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/seta_voltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:maxImageSize="36dp"
        app:backgroundTint="@color/transparente"
        app:rippleColor="@color/transparente"
        app:borderWidth="0dp"
        android:elevation="0dp"
        app:elevation="0dp"
        app:pressedTranslationZ="0dp"/>


</androidx.constraintlayout.widget.ConstraintLayout>