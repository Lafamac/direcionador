<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_9"
    tools:context=".Centralizador.CentralizadorRelatorio">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/centRel_voltar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:elevation="0dp"
        android:src="@drawable/seta_voltar_preta"
        app:backgroundTint="@color/ap_transparent"
        app:borderWidth="0dp"
        app:elevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:maxImageSize="36dp"
        app:pressedTranslationZ="0dp"
        app:rippleColor="@color/ap_transparent" />

    <TextView
        android:id="@+id/txt_titulo_relatorio"
        style="@style/textoBoldBlack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Histórico de Produção"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="@+id/centRel_voltar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/centRel_voltar"
        app:layout_constraintTop_toTopOf="@+id/centRel_voltar" />

    <LinearLayout
        android:id="@+id/layout_filtros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/centRel_voltar">

        <com.skydoves.powerspinner.PowerSpinnerView
            android:id="@+id/spinner_filtro_data"
            style="@style/PowerSpinnerStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:hint="Data"
            android:padding="10dp"
            app:spinner_arrow_gravity="end"
            app:spinner_arrow_padding="8dp"
            app:spinner_popup_animation="dropdown"
            app:spinner_popup_background="@drawable/fundo_branco_borda"
            app:spinner_popup_elevation="14dp" />

        <com.skydoves.powerspinner.PowerSpinnerView
            android:id="@+id/spinner_filtro_operador"
            style="@style/PowerSpinnerStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:hint="Operador"
            android:padding="10dp"
            app:spinner_arrow_gravity="end"
            app:spinner_arrow_padding="8dp"
            app:spinner_popup_animation="dropdown"
            app:spinner_popup_background="@drawable/fundo_branco_borda"
            app:spinner_popup_elevation="14dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_limpar_filtros"
        android:layout_width="wrap_content"
        android:layout_height="35dp"
        android:layout_marginTop="8dp"
        android:background="@android:color/transparent"
        android:text="Limpar Filtros"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_filtros" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_eventos_producao"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintBottom_toTopOf="@+id/centRel_finalizar"
        app:layout_constraintTop_toBottomOf="@+id/btn_limpar_filtros" />

    <TextView
        android:id="@+id/txt_sem_dados"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nenhum dado encontrado para os filtros."
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/centRel_finalizar"
        style="@style/botaoPreto"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:text="@string/botaoFinalizar"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Mantendo IDs para compatibilidade se necessário -->
    <TextView android:id="@+id/centRel_porcentagemD" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
    <TextView android:id="@+id/centRel_porcentagemE" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
    <TextView android:id="@+id/centRel_porcentagemC" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
    <com.skydoves.powerspinner.PowerSpinnerView android:id="@+id/centRel_spinnerDatas" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
