<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_9">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/centRel_voltar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/seta_voltar_preta"
        app:backgroundTint="@color/ap_transparent"
        app:borderWidth="0dp"
        app:elevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:maxImageSize="30dp" />

    <TextView
        android:id="@+id/txt_titulo_relatorio"
        style="@style/textoBoldBlack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Histórico"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/centRel_voltar"
        app:layout_constraintStart_toEndOf="@+id/centRel_voltar"
        app:layout_constraintTop_toTopOf="@+id/centRel_voltar" />

    <com.skydoves.powerspinner.PowerSpinnerView
        android:id="@+id/spinner_filtro_data"
        style="@style/PowerSpinnerStyle"
        android:layout_width="120dp"
        android:layout_height="35dp"
        android:layout_marginStart="16dp"
        android:hint="Data"
        android:padding="5dp"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/centRel_voltar"
        app:layout_constraintStart_toEndOf="@+id/txt_titulo_relatorio"
        app:layout_constraintTop_toTopOf="@+id/centRel_voltar"
        app:spinner_arrow_gravity="end"
        app:spinner_popup_background="@drawable/fundo_branco_borda" />

    <com.skydoves.powerspinner.PowerSpinnerView
        android:id="@+id/spinner_filtro_operador"
        style="@style/PowerSpinnerStyle"
        android:layout_width="120dp"
        android:layout_height="35dp"
        android:layout_marginStart="8dp"
        android:hint="Operador"
        android:padding="5dp"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/centRel_voltar"
        app:layout_constraintStart_toEndOf="@+id/spinner_filtro_data"
        app:layout_constraintTop_toTopOf="@+id/centRel_voltar"
        app:spinner_arrow_gravity="end"
        app:spinner_popup_background="@drawable/fundo_branco_borda" />

    <Button
        android:id="@+id/btn_limpar_filtros"
        android:layout_width="wrap_content"
        android:layout_height="35dp"
        android:layout_marginStart="8dp"
        android:background="@android:color/transparent"
        android:text="Limpar"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="@+id/centRel_voltar"
        app:layout_constraintStart_toEndOf="@+id/spinner_filtro_operador"
        app:layout_constraintTop_toTopOf="@+id/centRel_voltar" />

    <Button
        android:id="@+id/centRel_finalizar"
        style="@style/botaoPreto"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:text="@string/botaoFinalizar"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/centRel_voltar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/centRel_voltar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_eventos_producao"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/centRel_voltar" />

    <TextView
        android:id="@+id/txt_sem_dados"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nenhum dado."
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
