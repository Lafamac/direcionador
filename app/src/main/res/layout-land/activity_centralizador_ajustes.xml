<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_9"
    tools:context=".Centralizador.CentralizadorAjustes">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/centSens_guide1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.05" />

    <ScrollView
        android:id="@+id/scrollViewAjustes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/containerBotoes"
        app:layout_constraintTop_toBottomOf="@id/centSens_guide1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp">

            <!-- Linha 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/distanciaBarras"
                        style="@style/textoBoldBlack"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/centAjus_fieldDistBarra"
                        style="@style/CamposDeTexto"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:inputType="number"
                        android:hint="@string/milimetros"
                        android:textSize="14sp"
                        android:paddingStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/menorDistancia"
                        style="@style/textoBoldBlack"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/centAjus_fieldDistMin"
                        style="@style/CamposDeTexto"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:inputType="number"
                        android:hint="@string/milimetros"
                        android:textSize="14sp"
                        android:paddingStart="12dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Linha 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/distanciaValida"
                        style="@style/textoBoldBlack"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/centAjus_fieldDistMax"
                        style="@style/CamposDeTexto"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:inputType="number"
                        android:hint="@string/milimetros"
                        android:textSize="14sp"
                        android:paddingStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/diametro"
                        style="@style/textoBoldBlack"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/centAjus_fieldDiam"
                        style="@style/CamposDeTexto"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:inputType="number"
                        android:hint="@string/milimetros"
                        android:textSize="14sp"
                        android:paddingStart="12dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Linha 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tempo de atualização"
                        style="@style/textoBoldBlack"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/centAjus_fieldTemp"
                        style="@style/CamposDeTexto"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:inputType="numberDecimal"
                        android:hint="@string/segundos"
                        android:textSize="14sp"
                        android:paddingStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tempo Fixo (1.0 a 1.5s)"
                        style="@style/textoBoldBlack"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/centAjus_fieldTempoFixo"
                        style="@style/CamposDeTexto"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:inputType="numberDecimal"
                        android:hint="Ex: 1.3"
                        android:textSize="14sp"
                        android:paddingStart="12dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Linha 4 (Switch) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="6dp"
                android:paddingVertical="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Liberar Scroll para Operador"
                    style="@style/textoBoldBlack"
                    android:textSize="14sp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/centAjus_swHabilitaScroll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:checked="true" />
            </LinearLayout>

            <!-- Elementos ocultos para compatibilidade com o Java -->
            <ImageButton android:id="@+id/centAjus_okAngulo" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageButton android:id="@+id/centAjus_okDistBarra" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageButton android:id="@+id/centAjus_okDistMin" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageButton android:id="@+id/centAjus_okDistMax" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageButton android:id="@+id/centAjus_okDiam" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageButton android:id="@+id/centAjus_okTempo" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <EditText android:id="@+id/centAjus_fieldAngulo" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:inputType="number" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/centSens_tps" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/centSens_pagina" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/containerBotoes"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/centSens_voltar"
            style="@style/textoBotoes"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="16dp"
            android:text="@string/botaoVoltar"
            android:textSize="16sp" />

        <Button
            android:id="@+id/centSens_avancar"
            style="@style/textoBotoes"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="@string/botaoAvancar"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>